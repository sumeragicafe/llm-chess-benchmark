{
  "name": "llm-chess-benchmark",
  "version": "1.0.0",
  "description": "CLI tool to benchmark LLMs on chess puzzles using the Lichess API",
  "type": "module",
  "bin": {
    "llm-chess-benchmark": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "tsx --test test/test.ts"
